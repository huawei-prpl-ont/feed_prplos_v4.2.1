config PACKAGE_tr181-ppp
    tristate
    select SAH_AMX_TR181_PPP

if PACKAGE_tr181-ppp

menu "Select tr181-ppp build options"
    depends on PACKAGE_tr181-ppp

config SAH_AMX_TR181_PPP
    bool "Build TR-181 compatible PPP plugin"
    default y

config SAH_AMX_TR181_PPP_START_ORDER
    int "Init start up order for the TR-181 compatible PPP plugin"
    default 26

config SAH_AMX_TR181_PPP_STOP_ORDER
    int "Init stop order for the TR-181 compatible PPP plugin"
    default 74

endmenu

endif
