+static bool valid_rule_mask(const amxc_var_t* const args) {
+    int prefixlen = 0;
+    const char* mask = GET_CHAR(args, NULL);
+
+    if(STRING_EMPTY(mask)) {
+        return true;
+    }
+
+    return address_parse_rule_mask_prefixlen(mask, &prefixlen);
+}
+
+static bool valid_ip_address(const amxc_var_t* const args) {
+    ipat_t ip = IPAT_INITIALIZE;
+    const char* ip_address = GET_CHAR(args, NULL);
+
+    if(STRING_EMPTY(ip_address)) {
+        return true;
+    }
+
+    if(strchr(ip_address, '/') != NULL) {
+        return false;
+    }
+
+    return ipat_pton(&ip, AF_INET_ANY, ip_address) && ipat_valid(&ip);
+}
+
 amxd_status_t _fw_is_valid_prefix(UNUSED amxd_object_t* object,
                                   UNUSED amxd_param_t* param,
                                   amxd_action_t reason,
@@ -206,4 +235,48 @@ amxd_status_t _fw_is_valid_ipv4_prefix(UNUSED amxd_object_t* object,
 exit:
     FW_PROFILING_OUT();
     return status;
-}
\ No newline at end of file
+}
+
+amxd_status_t _fw_is_valid_rule_mask(UNUSED amxd_object_t* object,
+                                     UNUSED amxd_param_t* param,
+                                     amxd_action_t reason,
+                                     const amxc_var_t* const args,
+                                     UNUSED amxc_var_t* const retval,
+                                     UNUSED void* priv) {
+    FW_PROFILING_IN(TRACE_DM_ACTION);
+    amxd_status_t status = amxd_status_unknown_error;
+
+    when_true_status(reason != action_param_validate,
+                     exit,
+                     status = amxd_status_function_not_implemented);
+
+    when_false_status(valid_rule_mask(args), exit, status = amxd_status_invalid_arg);
+
+    status = amxd_status_ok;
+
+exit:
+    FW_PROFILING_OUT();
+    return status;
+}
+
+amxd_status_t _fw_is_valid_ip_address(UNUSED amxd_object_t* object,
+                                      UNUSED amxd_param_t* param,
+                                      amxd_action_t reason,
+                                      const amxc_var_t* const args,
+                                      UNUSED amxc_var_t* const retval,
+                                      UNUSED void* priv) {
+    FW_PROFILING_IN(TRACE_DM_ACTION);
+    amxd_status_t status = amxd_status_unknown_error;
+
+    when_true_status(reason != action_param_validate,
+                     exit,
+                     status = amxd_status_function_not_implemented);
+
+    when_false_status(valid_ip_address(args), exit, status = amxd_status_invalid_arg);
+
+    status = amxd_status_ok;
+
+exit:
+    FW_PROFILING_OUT();
+    return status;
+}
