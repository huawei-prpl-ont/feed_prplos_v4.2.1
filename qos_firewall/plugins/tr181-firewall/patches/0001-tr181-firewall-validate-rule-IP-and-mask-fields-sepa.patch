diff --git a/src/ip_address.c b/src/ip_address.c
index ff41911..779e03d 100644
--- a/src/ip_address.c
+++ b/src/ip_address.c
@@ -67,6 +67,7 @@
 #include <debug/sahtrace.h>
 #include <debug/sahtrace_macros.h>
 #include <ipat/ipat.h>
+#include <stdlib.h>
 #include <string.h>
 
 #define ME "firewall"
@@ -94,6 +95,85 @@ ipversion_t int_to_ipversion(int value) {
     return version;
 }
 
+ipversion_t address_string_ipversion(const char* address) {
+    ipversion_t version = IPvUnknown;
+    ipat_t ip = IPAT_INITIALIZE;
+
+    if(STRING_EMPTY(address)) {
+        return IPvAll;
+    }
+
+    if(!ipat_pton(&ip, AF_INET_ANY, address) || !ipat_valid(&ip)) {
+        return IPvUnknown;
+    }
+
+    version = (ipat_family(&ip) == AF_INET) ? IPv4 : IPv6;
+    return version;
+}
+
+bool address_parse_rule_mask_prefixlen(const char* mask, int* prefixlen) {
+    bool valid = false;
+    char* endptr = NULL;
+
+    when_str_empty(mask, exit);
+    when_null(prefixlen, exit);
+
+    if(mask[0] == '/') {
+        long parsed = 0;
+
+        when_true(mask[1] == '\0', exit);
+        parsed = strtol(mask + 1, &endptr, 10);
+        when_false((endptr != NULL) && (*endptr == '\0'), exit);
+        when_false((parsed >= 0) && (parsed <= 128), exit);
+        *prefixlen = (int) parsed;
+        valid = true;
+        goto exit;
+    }
+
+    if(strchr(mask, '/') != NULL) {
+        ipat_t prefix = IPAT_INITIALIZE;
+
+        when_false(ipat_pton(&prefix, AF_INET_ANY, mask), exit);
+        *prefixlen = ipat_prefix_length(&prefix);
+        valid = ipat_valid(&prefix);
+    }
+
+exit:
+    return valid;
+}
+
+bool address_rule_ip_mask_compatible(const char* ip, const char* mask, ipversion_t rule_ipversion) {
+    ipversion_t ipversion = IPvAll;
+    int prefixlen = 0;
+
+    if(STRING_EMPTY(ip)) {
+        return STRING_EMPTY(mask);
+    }
+
+    ipversion = address_string_ipversion(ip);
+    if(ipversion == IPvUnknown) {
+        return false;
+    }
+
+    if((rule_ipversion > IPvAll) && (ipversion != rule_ipversion)) {
+        return false;
+    }
+
+    if(STRING_EMPTY(mask)) {
+        return true;
+    }
+
+    if(!address_parse_rule_mask_prefixlen(mask, &prefixlen)) {
+        return false;
+    }
+
+    if((ipversion == IPv4) && (prefixlen > 32)) {
+        return false;
+    }
+
+    return true;
+}
