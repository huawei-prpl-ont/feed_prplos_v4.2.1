+            } else {
+                ip = object_da_string(obj, param_ip);
+            }
+            apply_masked_ip(rule, param_mask, mask, param_ip, ip, apply_ip);
             goto exit;
         }
     } else {
-        ip = object_da_string(obj, param_mask);
-        if(!STRING_EMPTY(ip)) {
-            goto exit; // already in use
+        mask = object_da_string(obj, param_mask);
+        if(!STRING_EMPTY(mask)) {
