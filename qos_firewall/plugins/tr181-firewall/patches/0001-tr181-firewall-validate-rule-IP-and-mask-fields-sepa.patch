+static void apply_masked_ip(rule_t* rule,
+                            const char* param_mask,
+                            const char* mask,
+                            const char* param_ip,
+                            const char* ip,
+                            void (* apply_ip)(rule_t*, const char*)) {
+    amxc_string_t buf;
+    char* network = NULL;
+    int prefixlen = 0;
+
+    amxc_string_init(&buf, 0);
+
+    if(STRING_EMPTY(ip)) {
+        apply_ip(rule, "");
+        goto exit;
+    }
+
+    if(!address_rule_ip_mask_compatible(ip, mask, IPvAll)) {
+        apply_ip(rule, "");
+        goto exit;
+    }
+
+    when_false_trace(address_parse_rule_mask_prefixlen(mask, &prefixlen), exit, ERROR, "Failed to parse %s[%s]", param_mask, mask);
+
+    network = ipat_text_mask_apply_direct(ip, prefixlen, ipat_bits_upper, ipat_oper_and, false);
+    when_null_trace(network, exit, ERROR, "Failed to apply %s[%s] to %s[%s]", param_mask, mask, param_ip, ip);
+
+    amxc_string_setf(&buf, "%s/%d", network, prefixlen);
+    apply_ip(rule, amxc_string_get(&buf, 0));
+
+exit:
+    free(network);
+    amxc_string_clean(&buf);
+}
