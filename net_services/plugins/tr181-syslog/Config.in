config PACKAGE_tr181-syslog
    tristate
    select SAH_AMX_TR181_SYSLOG

if PACKAGE_tr181-syslog

menu "Select tr181-syslog build options"
    depends on PACKAGE_tr181-syslog

config SAH_AMX_TR181_SYSLOG
    bool "TR-181 compatible syslog"
    default y

config SAH_AMX_TR181_SYSLOG_START_ORDER
    int "Init start up order for the TR-181 compatible syslog"
    default 12

config SAH_AMX_TR181_SYSLOG_STOP_ORDER
    int "Init stop order for the TR-181 compatible syslog"
    default 88

endmenu

endif
